# Copy this file to .env.production (never commit it).
#
# When deploying to Vercel with the Python backend on the same project:
#   - Leave NEXT_PUBLIC_API_URL empty (browser will use relative /api/* URLs).
#   - Vercel auto-injects VERCEL_URL for server-side (SSR) fetches — no action needed.
#   - Set CORS_ORIGINS in Vercel env vars to ["https://<your-app>.vercel.app"].
#
# When deploying the backend separately (Render / Railway):
#   - Set NEXT_PUBLIC_API_URL to the full backend URL, e.g. https://stock-view-api.onrender.com

NEXT_PUBLIC_API_URL=
